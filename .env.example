# Optional: Ollama laeuft standardmaessig lokal auf diesem Port.
OLLAMA_BASE_URL=http://localhost:11434

# Diese Modelle muessen lokal in Ollama vorhanden sein:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Separater Ordner, damit alte OpenAI-Vektoren nicht mit Ollama kollidieren.
CHROMA_DIR=chroma_db_ollama
